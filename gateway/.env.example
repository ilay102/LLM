# Copy to `.env` and fill in. Never commit real keys.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Gateway auth — clients send this as their "OpenAI" key.
# Rotate per-tenant in prod; here a single shared dev key is fine.
GATEWAY_MASTER_KEY=dev-key-change-me

# Routing knobs
SEMANTIC_CACHE_THRESHOLD=0.95   # cosine similarity for cache hit
SEMANTIC_CACHE_TTL_SECONDS=86400
ENABLE_SEMANTIC_CACHE=true
ENABLE_CLASSIFIER=true
SHADOW_LOG_PATH=/app/shadow_log.jsonl  # post-hook writes every call here

# Optional
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
